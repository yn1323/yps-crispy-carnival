{
  "name": "yps-crispy-carnival",
  "version": "0.0.18",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "type": "module",
  "scripts": {
    "build": "vite build && tsc",
    "prerender": "tsx scripts/prerender.ts",
    "dev": "vite --port 3000",
    "dev:ngrok": "concurrently -n dev,ngrok -c blue,cyan \"vite --port 3000 --host 0.0.0.0\" \"tsx scripts/startNgrok.ts\"",
    "dev:all": "concurrently -n dev,convex,storybook -c blue,green,magenta \"pnpm dev\" \"pnpm convex:dev\" \"pnpm storybook\"",
    "ngrok:auth": "tsx scripts/setupNgrokAuth.ts",
    "format": "biome check --write",
    "lint": "biome check",
    "lint:font-size": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-font-size-tokens.ps1",
    "type-check": "tsc",
    "scaffdog": "scaffdog generate",
    "serve": "vite preview",
    "start": "vite --port 3000",
    "difit": "npx -y difit .",
    "test": "vitest",
    "test:logic": "vitest --project=logic",
    "test:ui": "vitest --project=ui",
    "test:convex": "vitest --project='convex(logic)' --project='convex(scenario)'",
    "test:convex:logic": "vitest --project='convex(logic)'",
    "test:convex:scenario": "vitest --project='convex(scenario)'",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:no-report": "playwright test --reporter=line",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build  --stats-json",
    "convex:dev": "npx convex dev",
    "convex:configure": "npx convex dev --configure",
    "convex:clear": "npx convex run testing:clearAllTables",
    "cconvex:clearAllTables:dev": "npx convex run testing:clearAllTables --deployment dev",
    "cconvex:clearAllTables:prod": "npx convex run testing:clearAllTables --prod",
    "convex:restore": "tsx convex-seeds/scripts/import.ts",
    "convex:save": "tsx convex-seeds/scripts/export.ts",
    "convex:env-setup": "tsx scripts/setupEnv.ts",
    "convex:migrate": "npx convex run migrations/index:run",
    "convex:migrate:status": "npx convex run --component migrations lib:getStatus --watch"
  },
  "dependencies": {
    "@chakra-ui/react": "3.35.0",
    "@clerk/clerk-react": "5.61.3",
    "@clerk/localizations": "3.37.3",
    "@convex-dev/migrations": "^0.3.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "11.14.0",
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-router": "1.169.8",
    "@tanstack/router-plugin": "1.167.41",
    "convex": "1.38.0",
    "convex-helpers": "^0.1.114",
    "dayjs": "^1.11.19",
    "jotai": "2.16.1",
    "next-themes": "0.4.6",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.75.0",
    "react-icons": "5.5.0",
    "react-joyride": "^3.0.2",
    "resend": "^6.9.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@clerk/testing": "1.14.6",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "1.57.0",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-vitest": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@tanstack/react-devtools": "0.10.3",
    "@tanstack/react-router-devtools": "1.166.19",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.1",
    "@types/node": "24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/unzipper": "0.10.11",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "@yn1323/cognac": "^0.2.2",
    "chromatic": "13.3.5",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.44",
    "dotenv": "17.2.3",
    "jsdom": "27.4.0",
    "playwright": "1.57.0",
    "scaffdog": "4.1.0",
    "storybook": "10.3.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4",
    "web-vitals": "5.1.0"
  }
}
