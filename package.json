{
  "name": "yps-crispy-carnival",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && tsc",
    "dev": "vite --port 3000",
    "dev:all": "concurrently -n dev,convex,storybook -c blue,green,magenta \"pnpm dev\" \"pnpm convex:dev\" \"pnpm storybook\"",
    "format": "biome check --write",
    "lint": "biome check",
    "type-check": "tsc",
    "scaffdog": "scaffdog generate",
    "serve": "vite preview",
    "start": "vite --port 3000",
    "difit": "npx -y difit .",
    "test": "vitest",
    "test:logic": "vitest --project=logic",
    "test:ui": "vitest --project=ui",
    "test:convex": "vitest --project=convex",
    "test:convex:once": "vitest run --project=convex",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:no-report": "playwright test --reporter=line",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build  --stats-json",
    "convex:dev": "npx convex dev",
    "convex:clear": "npx convex run testing:clearAllTables",
    "convex:restore": "tsx convex-seeds/scripts/import.ts",
    "convex:save": "tsx convex-seeds/scripts/export.ts",
    "convex:env-setup": "tsx scripts/setupEnv.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "3.30.0",
    "@clerk/clerk-react": "5.61.3",
    "@clerk/localizations": "3.37.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "11.14.0",
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/router-plugin": "1.167.12",
    "convex": "1.34.1",
    "convex-helpers": "^0.1.114",
    "dayjs": "^1.11.19",
    "jotai": "2.16.1",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.1",
    "react-icons": "5.5.0",
    "resend": "^6.9.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@clerk/testing": "1.14.4",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "1.57.0",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-mcp": "^0.5.0",
    "@storybook/addon-vitest": "10.3.3",
    "@storybook/react-vite": "10.3.3",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router-devtools": "1.166.11",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/unzipper": "0.10.11",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "@yn1323/cognac": "^0.2.2",
    "chromatic": "13.3.5",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.44",
    "dotenv": "17.2.3",
    "jsdom": "27.4.0",
    "playwright": "1.57.0",
    "scaffdog": "4.1.0",
    "storybook": "10.3.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4",
    "web-vitals": "5.1.0"
  }
}
